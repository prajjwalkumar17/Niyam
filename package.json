{
  "name": "niyam",
  "version": "1.0.0",
  "description": "CLI Command Governance System - Policy engine with approval workflows",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test",
    "init-db": "node db/init.js",
    "setup:interactive": "bash ./oneclick-setup.sh",
    "start:guided": "bash ./oneclick-setup.sh",
    "smoke": "sh scripts/smoke.sh",
    "smoke:wrapper": "NIYAM_SMOKE_WRAPPER_TEST=1 sh scripts/smoke.sh",
    "smoke:dashboard": "node scripts/dashboard_smoke.js",
    "smoke:dashboard:reset": "node scripts/dashboard_smoke_reset.js",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "rotate:exec-key": "node scripts/rotate_exec_key.js",
    "load": "node scripts/load.js",
    "soak": "node scripts/soak.js",
    "install:render": "sh scripts/install.sh render",
    "install:stage": "sh scripts/install.sh install",
    "package:selfhost": "sh scripts/package.sh"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^4.18.2",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
